# ============================================================
# MITHYA FRONTEND - ENVIRONMENT VARIABLES
# ============================================================
#
# STRICT SECURITY RULE:
# The ONLY environment variable allowed in this file is VITE_API_BASE_URL.
#
# ❌ NEVER PUT HERE:
#    - MONGO_URI or any database connection strings
#    - Supabase keys or any third-party service credentials
#    - API secrets, passwords, or tokens of any kind
#
# React/Vite bundles EVERYTHING into public JavaScript.
# Anyone can read your .env values by pressing F12 in the browser.
# All secrets MUST live ONLY on the backend (app.py / Azure App Service env vars).
#
# ============================================================

# Point to your local Flask backend during development:
VITE_API_BASE_URL=http://127.0.0.1:5000

# When deploying to Azure, change this ONE value to your App Service URL:
# VITE_API_BASE_URL=https://your-flask-api.azurewebsites.net
